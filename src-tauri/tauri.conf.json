{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Storyboard Pacer",
  "version": "0.1.0",
  "identifier": "ca.jennychen.storyboardpacer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Storyboard Pacer",
        "width": 1080,
        "height": 900,
        "minWidth": 720,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
